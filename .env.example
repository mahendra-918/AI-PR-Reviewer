# ─────────────────────────────────────────
# AI PR Reviewer — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# GitHub App Credentials
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./certs/github_app.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_APP_INSTALLATION_ID=

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pr_reviewer
POSTGRES_USER=pr_reviewer_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://pr_reviewer_user:changeme@localhost:5432/pr_reviewer

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3

# Vector DB (Weaviate)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# Static Analysis
BANDIT_ENABLED=true
SEMGREP_ENABLED=true
ESLINT_ENABLED=true
